@page "/subscriptions"
@namespace ServiceBusConsole.Pages
@implements IDisposable

@inject NavigationManager Nav
@inject ServiceBusConnection Connection
@inject ITopicService TopicService

<Rows @onkeydown="HandleKeyDown">
    <Panel BorderColor="@Color.Grey37" Expand="true" Padding="@(new(0, 0, 0, 0))">
        <Markup Content="All Subscriptions" Foreground="@Color.DodgerBlue1" Decoration="@Decoration.Bold" />
    </Panel>

    <Padder Padding="@(new(0, 1, 0, 0))">
        <TextInput Value="@_filter"
                   ValueChanged="ApplyFilter"
                   OnFocus="@(_ => _filterFocused = true)"
                   OnBlur="@(_ => _filterFocused = false)"
                   Placeholder="Type to filter by topic or subscription..."
                   Expand="true"
                   FocusOrder="1" />
    </Padder>

    @if (_all.Count == 0)
    {
        <Padder Padding="@(new(0, 1, 0, 0))">
            <Columns>
                <RazorConsole.Components.Spinner SpinnerType="@Spectre.Console.Spinner.Known.Dots" />
                <Markup Content="Loading subscriptions..." Foreground="@Color.Grey" Decoration="@Decoration.Italic" />
            </Columns>
        </Padder>
    }
    else
    {
        <Padder Padding="@(new(0, 1, 0, 0))">
            <Markup Content="@($"{_filtered.Count} subscription(s)")" Foreground="@Color.Grey" />
        </Padder>

        <SpectreTable Expand="true" Border="TableBorder.Rounded">
            <SpectreTHead>
                <SpectreTR>
                    <SpectreTH Align="Justify.Left">Topic</SpectreTH>
                    <SpectreTH Align="Justify.Left">Subscription</SpectreTH>
                    <SpectreTH Align="Justify.Right">Active</SpectreTH>
                    <SpectreTH Align="Justify.Right">DLQ</SpectreTH>
                    <SpectreTH Align="Justify.Right">Transfer</SpectreTH>
                </SpectreTR>
            </SpectreTHead>
            <SpectreTBody>
                @{ var i = 0; }
                @foreach (var s in _filtered.Take(MaxRows))
                {
                    var captured = s;
                    var fo = 6 + i++;
                    <SpectreTR @key="@($"{captured.TopicName}/{captured.Name}")">
                        <SpectreTD>@s.TopicName</SpectreTD>
                        <SpectreTD>
                            <TextButton Content="@captured.Name"
                                        OnClick="@(() => Nav.NavigateTo($"/topics/{Uri.EscapeDataString(captured.TopicName)}/{Uri.EscapeDataString(captured.Name)}"))"
                                        FocusedColor="@Color.DodgerBlue1"
                                        FocusOrder="@fo"
                                        OnFocus="@(_ => _focusedItem = captured)"
                                        OnBlur="@(_ => _focusedItem = null)"
                                        OnKeyDown="@HandleKeyDown" />
                        </SpectreTD>
                        <SpectreTD Align="Justify.Right">@(s.IsRefreshing ? "…" : s.ActiveMessageCount.ToString())</SpectreTD>
                        <SpectreTD Align="Justify.Right">@(s.IsRefreshing ? "…" : s.DeadLetterMessageCount > 0 ? $"! {s.DeadLetterMessageCount}" : "0")</SpectreTD>
                        <SpectreTD Align="Justify.Right">@(s.IsRefreshing ? "…" : s.TransferMessageCount.ToString())</SpectreTD>
                    </SpectreTR>
                }
            </SpectreTBody>
        </SpectreTable>
    }

    <Padder Padding="@(new(1, 0, 0, 0))">
        <Columns>
            <TextButton Content="[F5] Refresh" OnClick="LoadSubscriptions" FocusedColor="@Color.Green" FocusOrder="2" OnKeyDown="@HandleKeyDown" />
            <Markup Content="   " />
            <TextButton Content="[F9] Delete" OnClick="TriggerDelete" FocusedColor="@Color.Red" FocusOrder="3" OnKeyDown="@HandleKeyDown" />
            <Markup Content="   " />
            <TextButton Content="[Esc] Back" OnClick="@(() => Nav.NavigateTo("/"))" FocusedColor="@Color.Yellow" FocusOrder="4" OnKeyDown="@HandleKeyDown" />
        </Columns>
    </Padder>
</Rows>

<ConfirmModal IsOpened="@(_pendingDelete is not null)"
              Message="@($"Delete subscription '{_pendingDelete?.Name}' from topic '{_pendingDelete?.TopicName}'? This cannot be undone.")"
              OnConfirm="ConfirmDelete"
              OnCancel="@(() => _pendingDelete = null)" />

<ErrorModal Message="@_error" OnDismiss="@(() => _error = string.Empty)" />

@code {
    private List<SubscriptionInfo> _all = [];
    private List<SubscriptionInfo> _filtered = [];
    private string? _filter;
    private bool _filterFocused;
    private SubscriptionInfo? _focusedItem;
    private SubscriptionInfo? _pendingDelete;
    private string _error = string.Empty;
    private CancellationTokenSource _cts = new();

    private static int MaxRows => Math.Max(5, Console.WindowHeight - 12);

    public void Dispose() { _cts.Cancel(); _cts.Dispose(); }


    protected override void OnInitialized()
    {
        if (Connection.CurrentNamespace is null)
            Nav.NavigateTo("/");
    }

    protected override async Task OnInitializedAsync() => await LoadSubscriptions();

    private async Task LoadSubscriptions()
    {
        _cts.Cancel();
        _cts = new CancellationTokenSource();
        _error = string.Empty;

        var seen = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
        var transitionRendered = false;

        try
        {
            await foreach (var s in TopicService.GetAllSubscriptionsAsync(_cts.Token))
            {
                var key = $"{s.TopicName}/{s.Name}";
                seen.Add(key);
                var idx = _all.FindIndex(x => x.TopicName == s.TopicName && x.Name == s.Name);
                if (idx >= 0) _all[idx] = s; else _all.Add(s);

                if (!s.IsRefreshing && !transitionRendered)
                {
                    transitionRendered = true;
                    SortAndUpdateFilterState();
                    await InvokeAsync(StateHasChanged);
                }
            }

            if (!_cts.IsCancellationRequested)
            {
                _all.RemoveAll(s => !seen.Contains($"{s.TopicName}/{s.Name}"));
                SortAndUpdateFilterState();
            }
            await InvokeAsync(StateHasChanged);
        }
        catch (OperationCanceledException) { }
        catch (Exception ex) { _error = ex.Message; await InvokeAsync(StateHasChanged); }
    }

    private void TriggerDelete()
    {
        if (_focusedItem is not null) { _pendingDelete = _focusedItem; StateHasChanged(); }
    }

    private async Task ConfirmDelete()
    {
        var sub = _pendingDelete!;
        _pendingDelete = null;
        _error = string.Empty;
        StateHasChanged();
        try
        {
            await TopicService.DeleteSubscriptionAsync(sub.TopicName, sub.Name);
            _all.RemoveAll(s => s.TopicName == sub.TopicName && s.Name == sub.Name);
            SortAndFilter();
        }
        catch (Exception ex) { _error = ex.Message; StateHasChanged(); }
    }

    private void SortAndUpdateFilterState()
    {
        _all = [.. _all.OrderByDescending(s => s.TotalMessageCount).ThenBy(s => s.TopicName).ThenBy(s => s.Name)];
        UpdateFilterState(_filter);
    }

    private void UpdateFilterState(string? value)
    {
        _filter = value;
        _filtered = string.IsNullOrWhiteSpace(value) ? _all
            : _all.Where(s => s.TopicName.Contains(value, StringComparison.OrdinalIgnoreCase)
                            || s.Name.Contains(value, StringComparison.OrdinalIgnoreCase)).ToList();
    }

    private void SortAndFilter()
    {
        _all = [.. _all.OrderByDescending(s => s.TotalMessageCount).ThenBy(s => s.TopicName).ThenBy(s => s.Name)];
        ApplyFilter(_filter);
    }

    private void ApplyFilter(string? value)
    {
        UpdateFilterState(value);
        StateHasChanged();
    }

    private void HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.CtrlKey || e.AltKey || e.MetaKey) return;
        switch (e.Key)
        {
            case "Escape": Nav.NavigateTo("/"); return;
            case "F5": _ = LoadSubscriptions(); return;
            case "F9": case "Delete": case "\\": TriggerDelete(); return;
            case "Backspace":
                if (!_filterFocused) ApplyFilter(string.IsNullOrEmpty(_filter) ? null : _filter[..^1]);
                return;
            default:
                if (!_filterFocused && e.Key.Length == 1 && !char.IsControl(e.Key[0]))
                    ApplyFilter((_filter ?? "") + e.Key);
                break;
        }
    }
}

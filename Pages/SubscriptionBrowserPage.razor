@page "/topics/{TopicName}/{SubscriptionName}"
@namespace ServiceBusConsole.Pages

@inject NavigationManager Nav
@inject IMessageService MessageService
@inject NavigationState NavState

<Rows @onkeydown="HandleKeyDown">
    <Panel BorderColor="@Color.Grey37" Expand="true" Padding="@(new(0, 0, 0, 0))">
        <Columns>
            <Markup Content="Topics" Foreground="@Color.Grey" />
            <Markup Content=" › " Foreground="@Color.Grey" />
            <Markup Content="@TopicName" Foreground="@Color.Grey" />
            <Markup Content=" › " Foreground="@Color.Grey" />
            <Markup Content="@SubscriptionName" Foreground="@Color.DodgerBlue1" Decoration="@Decoration.Bold" />
            @if (_isDlq) { <Markup Content=" (DLQ)" Foreground="@Color.Yellow" /> }
            @if (_isAutoForwarding) { <Markup Content=" (auto-forwarding)" Foreground="@Color.Grey" /> }
        </Columns>
    </Panel>

    @if (_loading)
    {
        <Padder Padding="@(new(0, 1, 0, 0))">
            <Columns>
                <RazorConsole.Components.Spinner SpinnerType="@Spectre.Console.Spinner.Known.Dots" />
                <Markup Content="Loading messages..." Foreground="@Color.Grey" Decoration="@Decoration.Italic" />
            </Columns>
        </Padder>
    }
    else if (_messages.Count > 0)
    {
        <Padder Padding="@(new(0, 1, 0, 0))">
            <Markup Content="@($"{_messages.Count} message(s)")" Foreground="@Color.Grey" />
        </Padder>

        <SpectreTable Expand="true" Border="TableBorder.Simple">
            <SpectreTHead>
                <SpectreTR>
                    <SpectreTH Align="Justify.Right">#</SpectreTH>
                    <SpectreTH Align="Justify.Left">Message ID</SpectreTH>
                    <SpectreTH Align="Justify.Left">Subject</SpectreTH>
                    <SpectreTH Align="Justify.Left">Enqueued</SpectreTH>
                    <SpectreTH Align="Justify.Right">Delivery</SpectreTH>
                </SpectreTR>
            </SpectreTHead>
            <SpectreTBody>
                @{ var i = 0; }
                @foreach (var m in _messages)
                {
                    var captured = m;
                    var fo = 6 + i++;
                    <SpectreTR @key="captured.SequenceNumber">
                        <SpectreTD Align="Justify.Right">
                            <TextButton Content="@captured.SequenceNumber.ToString()"
                                        OnClick="@(() => ViewMessage(captured))"
                                        FocusedColor="@Color.DodgerBlue1"
                                        FocusOrder="@fo"
                                        OnFocus="@(_ => _focusedMessage = captured)"
                                        OnBlur="@(_ => _focusedMessage = null)"
                                        OnKeyDown="@HandleKeyDown" />
                        </SpectreTD>
                        <SpectreTD>@Truncate(m.MessageId, 30)</SpectreTD>
                        <SpectreTD>@Truncate(m.Subject, 25)</SpectreTD>
                        <SpectreTD>@m.EnqueuedTime.LocalDateTime.ToString("HH:mm:ss")</SpectreTD>
                        <SpectreTD Align="Justify.Right">@m.DeliveryCount</SpectreTD>
                    </SpectreTR>
                }
            </SpectreTBody>
        </SpectreTable>
    }
    else
    {
        <Padder Padding="@(new(0, 1, 0, 0))">
            <Markup Content="@(_isAutoForwarding ? "Auto-forwarding enabled — messages are forwarded to another entity." : "No messages. Use F7 Peek or F8 Receive to load.")"
                    Foreground="@Color.Grey" Decoration="@Decoration.Italic" />
        </Padder>
    }

    <Padder Padding="@(new(1, 0, 0, 0))">
        <Columns>
            <TextButton Content="[F7] Peek" OnClick="PeekMessages" FocusedColor="@Color.Green" FocusOrder="2" OnKeyDown="@HandleKeyDown" />
            <Markup Content="   " />
            <TextButton Content="[F8] Receive" OnClick="ReceiveMessages" FocusedColor="@Color.Red" FocusOrder="3" OnKeyDown="@HandleKeyDown" />
            <Markup Content="   " />
            @if (!_isDlq)
            {
                <TextButton Content="[F6] View DLQ" OnClick="@(() => SwitchDlq(true))" FocusedColor="@Color.Yellow" FocusOrder="4" OnKeyDown="@HandleKeyDown" />
            }
            else
            {
                <TextButton Content="[F6] View Active" OnClick="@(() => SwitchDlq(false))" FocusedColor="@Color.Green" FocusOrder="4" OnKeyDown="@HandleKeyDown" />
            }
            <Markup Content="   " />
            <TextButton Content="[F9] Delete" OnClick="TriggerDelete" FocusedColor="@Color.Red" FocusOrder="5" OnKeyDown="@HandleKeyDown" />
            <Markup Content="   " />
            <TextButton Content="[Esc] Back" OnClick="@(() => Nav.NavigateTo($"/topics/{Uri.EscapeDataString(TopicName)}"))" FocusedColor="@Color.Yellow" FocusOrder="1" OnKeyDown="@HandleKeyDown" />
        </Columns>
    </Padder>
</Rows>

<ConfirmModal IsOpened="@(_pendingDelete is not null)"
              Message="@($"Delete message #{_pendingDelete?.SequenceNumber}?")"
              OnConfirm="ConfirmDelete"
              OnCancel="@(() => _pendingDelete = null)" />

<ErrorModal Message="@_error" OnDismiss="@(() => _error = string.Empty)" />

@code {
    [Parameter] public string TopicName { get; set; } = "";
    [Parameter] public string SubscriptionName { get; set; } = "";

    private bool _isDlq;
    private bool _isAutoForwarding;
    private List<MessageInfo> _messages = [];
    private bool _loading;
    private string _error = string.Empty;
    private MessageInfo? _focusedMessage;
    private MessageInfo? _pendingDelete;

    private static int MaxRows => Math.Max(5, Console.WindowHeight - 12);
    private MessageSource Source => new(SubscriptionName, _isDlq, TopicName, SubscriptionName);

    protected override async Task OnInitializedAsync() => await PeekMessages();

    private async Task SwitchDlq(bool dlq) { _isDlq = dlq; _messages = []; await PeekMessages(); }

    private async Task PeekMessages()
    {
        _loading = true; _error = string.Empty; _isAutoForwarding = false; StateHasChanged();
        try { _messages = await MessageService.PeekSubscriptionMessagesAsync(TopicName, SubscriptionName, MaxRows, _isDlq); }
        catch (Exception ex) when (ex.Message.Contains("auto-forwarding", StringComparison.OrdinalIgnoreCase)) { _isAutoForwarding = true; }
        catch (Exception ex) { _error = ex.Message.Split('\n')[0]; }
        _loading = false; StateHasChanged();
    }

    private async Task ReceiveMessages()
    {
        _loading = true; _error = string.Empty; StateHasChanged();
        try { _messages = await MessageService.ReceiveSubscriptionMessagesAsync(TopicName, SubscriptionName, MaxRows, _isDlq); }
        catch (Exception ex) when (ex.Message.Contains("auto-forwarding", StringComparison.OrdinalIgnoreCase)) { _isAutoForwarding = true; }
        catch (Exception ex) { _error = ex.Message.Split('\n')[0]; }
        _loading = false; StateHasChanged();
    }

    private void ViewMessage(MessageInfo msg)
    {
        NavState.Message = msg;
        NavState.MessageSource = Source;
        Nav.NavigateTo("/message");
    }

    private void TriggerDelete()
    {
        if (_focusedMessage is not null) { _pendingDelete = _focusedMessage; StateHasChanged(); }
    }

    private async Task ConfirmDelete()
    {
        var msg = _pendingDelete!;
        _pendingDelete = null; _error = string.Empty; StateHasChanged();
        try { await MessageService.DeleteMessageAsync(Source, msg.SequenceNumber); _messages.Remove(msg); }
        catch (Exception ex) { _error = ex.Message.Split('\n')[0]; }
        StateHasChanged();
    }

    private void HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.CtrlKey || e.AltKey || e.MetaKey) return;
        switch (e.Key)
        {
            case "Escape": Nav.NavigateTo($"/topics/{Uri.EscapeDataString(TopicName)}"); return;
            case "F6": _ = SwitchDlq(!_isDlq); return;
            case "F7": _ = PeekMessages(); return;
            case "F8": _ = ReceiveMessages(); return;
            case "F9": case "Delete": case "Backspace": TriggerDelete(); return;
        }
    }

    private static string Truncate(string value, int maxLength) =>
        value.Length <= maxLength ? value : value[..(maxLength - 1)] + "…";
}

@page "/topic-detail"
@namespace ServiceBusConsole.Pages
@implements IDisposable

@inject NavigationManager Nav
@inject NavigationState NavState
@inject ServiceBusConnection Connection
@inject ITopicService TopicService

<Rows @onkeydown="HandleKeyDown">
    <Panel BorderColor="@Color.Grey37" Expand="true" Padding="@(new(0, 0, 0, 0))">
        <Columns>
            <Markup Content="Topics" Foreground="@Color.Grey" />
            <Markup Content=" › " Foreground="@Color.Grey" />
            <Markup Content="@TopicName" Foreground="@Color.DodgerBlue1" Decoration="@Decoration.Bold" />
        </Columns>
    </Panel>

    @if (_subscriptions.Count == 0 && _loadFailed)
    {
        <Padder Padding="@(new(0, 1, 0, 0))">
            <Markup Content="Failed to load. Press [F5] to retry." Foreground="@Color.Red" />
        </Padder>
    }
    else if (_subscriptions.Count == 0)
    {
        <Padder Padding="@(new(0, 1, 0, 0))">
            <Columns>
                <RazorConsole.Components.Spinner SpinnerType="@Spectre.Console.Spinner.Known.Dots" />
                <Markup Content="Loading subscriptions..." Foreground="@Color.Grey" Decoration="@Decoration.Italic" />
            </Columns>
        </Padder>
    }
    else
    {
        <Padder Padding="@(new(0, 1, 0, 0))">
            <Markup Content="@($"{_subscriptions.Count} subscription(s)  |  Enter to browse · Backspace to delete")" Foreground="@Color.Grey" />
        </Padder>

        <Scrollable Items="@_subscriptions" PageSize="@(Math.Max(5, Console.WindowHeight - 12))" Scrollbar="new()"
                    SelectedIndex="@_selectedIndex"
                    SelectedIndexChanged="@(i => { _selectedIndex = i; _focusedItem = _subscriptions.ElementAtOrDefault(i)?.Name; })"
                    OnActivate="@(() => { if (_subscriptions.ElementAtOrDefault(_selectedIndex) is {} s) { NavState.TopicName = TopicName; NavState.SubscriptionName = s.Name; NavState.ReturnPath = "/topic-detail"; Nav.NavigateTo("/subscription-browser"); } })">
        <SpectreTable Expand="true" Border="TableBorder.Rounded">
            <SpectreTHead>
                <SpectreTR>
                    <SpectreTH Align="Justify.Left">Subscription</SpectreTH>
                    <SpectreTH Align="Justify.Right">Active</SpectreTH>
                    <SpectreTH Align="Justify.Right">DLQ</SpectreTH>
                    <SpectreTH Align="Justify.Right">Transfer</SpectreTH>
                    <SpectreTH></SpectreTH>
                </SpectreTR>
            </SpectreTHead>
            <SpectreTBody Navigable="true"
                          FocusOrder="4"
                          RowCount="@context.Items.Count"
                          OnKeyDown="@HandleKeyDown">
                @{ var i = 0; }
                @foreach (var s in context.Items)
                {
                    var idx = i++;
                    <SpectreTR @key="s.Name" RowIndex="@idx">
                        <SpectreTD>@s.Name</SpectreTD>
                        <SpectreTD Align="Justify.Right">@s.ActiveMessageCount</SpectreTD>
                        <SpectreTD Align="Justify.Right">@(s.DeadLetterMessageCount > 0 ? $"! {s.DeadLetterMessageCount}" : "0")</SpectreTD>
                        <SpectreTD Align="Justify.Right">@s.TransferMessageCount</SpectreTD>
                        <SpectreTD>@if (s.IsRefreshing) { <Spinner /> }</SpectreTD>
                    </SpectreTR>
                }
            </SpectreTBody>
        </SpectreTable>
        </Scrollable>
    }

    <Padder Padding="@(new(1, 0, 0, 0))">
        <Columns>
            <TextButton Content="[F5] Refresh" OnClick="LoadSubscriptions" FocusedColor="@Color.Green" FocusOrder="1" OnKeyDown="@HandleKeyDown" />
            <Markup Content="   " />
            <TextButton Content="[F9] Delete" OnClick="TriggerDelete" FocusedColor="@Color.Red" FocusOrder="2" OnKeyDown="@HandleKeyDown" />
            <Markup Content="   " />
            <TextButton Content="[Esc] Back" OnClick="@(() => Nav.NavigateTo("/topics"))" FocusedColor="@Color.Yellow" FocusOrder="3" OnKeyDown="@HandleKeyDown" />
        </Columns>
    </Padder>
</Rows>

<ConfirmModal IsOpened="@(_pendingDelete is not null)"
              Message="@($"Delete subscription '{_pendingDelete}' from topic '{TopicName}'? This cannot be undone.")"
              OnConfirm="ConfirmDelete"
              OnCancel="@(() => _pendingDelete = null)" />

<ErrorModal Message="@_error" OnDismiss="@(() => _error = string.Empty)" />

@code {
    private string TopicName => NavState.TopicName ?? "";

    private List<SubscriptionInfo> _subscriptions = [];
    private int _selectedIndex;
    private string? _focusedItem;
    private string? _pendingDelete;
    private string _error = string.Empty;
    private bool _loadFailed;
    private CancellationTokenSource _cts = new();

    public void Dispose() { _cts.Cancel(); _cts.Dispose(); }


    protected override void OnInitialized()
    {
        if (Connection.CurrentNamespace is null)
            Nav.NavigateTo("/");
        _focusedItem = NavState.SubscriptionName;
    }

    protected override async Task OnInitializedAsync() => await LoadSubscriptions();

    private async Task LoadSubscriptions()
    {
        _cts.Cancel();
        _cts = new CancellationTokenSource();
        _error = string.Empty;
        _loadFailed = false;

        var live = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
        var transitionRendered = false;

        try
        {
            await foreach (var s in TopicService.GetSubscriptionsAsync(TopicName, _cts.Token))
            {
                if (!s.IsRefreshing) live.Add(s.Name);
                var idx = _subscriptions.FindIndex(x => x.Name == s.Name);
                if (idx >= 0) _subscriptions[idx] = s; else _subscriptions.Add(s);

                if (!s.IsRefreshing && !transitionRendered)
                {
                    transitionRendered = true;
                    SortAndReanchor();
                    await InvokeAsync(StateHasChanged);
                }
                else if (!s.IsRefreshing)
                {
                    SortAndReanchor();
                }
            }

            if (!_cts.IsCancellationRequested)
                _subscriptions.RemoveAll(s => !live.Contains(s.Name));

            SortAndReanchor();
            await InvokeAsync(StateHasChanged);
        }
        catch (OperationCanceledException) { }
        catch (Exception ex) { _loadFailed = true; _error = ex.Message; await InvokeAsync(StateHasChanged); }
    }

    private void SortAndReanchor()
    {
        var focused = _focusedItem;
        _subscriptions = [.. _subscriptions.OrderBy(s => s.Name)];
        if (focused is not null)
        {
            var newIdx = _subscriptions.FindIndex(s => s.Name == focused);
            if (newIdx >= 0) _selectedIndex = newIdx;
        }
        _focusedItem = _subscriptions.ElementAtOrDefault(_selectedIndex)?.Name;
    }

    private void TriggerDelete()
    {
        if (_focusedItem is not null) { _pendingDelete = _focusedItem; StateHasChanged(); }
    }

    private async Task ConfirmDelete()
    {
        var name = _pendingDelete!;
        _pendingDelete = null;
        _error = string.Empty;
        StateHasChanged();
        try
        {
            await TopicService.DeleteSubscriptionAsync(TopicName, name);
            _subscriptions.RemoveAll(s => s.Name == name);
            _selectedIndex = Math.Min(_selectedIndex, Math.Max(0, _subscriptions.Count - 1));
            _focusedItem = _subscriptions.ElementAtOrDefault(_selectedIndex)?.Name;
            StateHasChanged();
        }
        catch (Exception ex) { _error = ex.Message; StateHasChanged(); }
    }

    private void HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.CtrlKey || e.AltKey || e.MetaKey) return;
        switch (e.Key)
        {
            case "Escape": Nav.NavigateTo("/topics"); return;
            case "F5": _ = LoadSubscriptions(); return;
            case "F9": case "Delete": case "\\": TriggerDelete(); return;
        }
    }
}

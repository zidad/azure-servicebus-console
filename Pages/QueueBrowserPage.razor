@page "/queues/{QueueName}"
@namespace ServiceBusConsole.Pages

@inject NavigationManager Nav
@inject ServiceBusConnection Connection
@inject IMessageService MessageService
@inject IQueueService QueueService
@inject NavigationState NavState

<Rows @onkeydown="HandleKeyDown">
    <Panel BorderColor="@Color.Grey37" Expand="true" Padding="@(new(0, 0, 0, 0))">
        <Columns>
            <Markup Content="Queues" Foreground="@Color.Grey" />
            <Markup Content=" › " Foreground="@Color.Grey" />
            <Markup Content="@QueueName" Foreground="@Color.DodgerBlue1" Decoration="@Decoration.Bold" />
            @if (_isDlq) { <Markup Content=" (DLQ)" Foreground="@Color.Yellow" /> }
        </Columns>
    </Panel>

    @if (_loading)
    {
        <Padder Padding="@(new(0, 1, 0, 0))">
            <Columns>
                <RazorConsole.Components.Spinner SpinnerType="@Spectre.Console.Spinner.Known.Dots" />
                <Markup Content="Loading messages..." Foreground="@Color.Grey" Decoration="@Decoration.Italic" />
            </Columns>
        </Padder>
    }
    else if (_messages.Count > 0)
    {
        <Padder Padding="@(new(0, 1, 0, 0))">
            <Markup Content="@($"{_messages.Count} message(s)")" Foreground="@Color.Grey" />
        </Padder>

        <Scrollable Items="@_messages" PageSize="@(Math.Max(5, Console.WindowHeight - 12))" Scrollbar="new()">
        <SpectreTable Expand="true" Border="TableBorder.Simple">
            <SpectreTHead>
                <SpectreTR>
                    <SpectreTH Align="Justify.Right">#</SpectreTH>
                    <SpectreTH Align="Justify.Left">Message ID</SpectreTH>
                    <SpectreTH Align="Justify.Left">Subject</SpectreTH>
                    <SpectreTH Align="Justify.Left">Enqueued</SpectreTH>
                    <SpectreTH Align="Justify.Right">Delivery</SpectreTH>
                </SpectreTR>
            </SpectreTHead>
            <SpectreTBody Navigable="true"
                          FocusOrder="7"
                          RowCount="@context.Items.Count"
                          SelectedIndex="@_selectedIndex"
                          SelectedIndexChanged="@(i => { _selectedIndex = i; _focusedMessage = context.Items.ElementAtOrDefault(i); })"
                          OnActivate="@(() => { if (context.Items.ElementAtOrDefault(_selectedIndex) is {} m) ViewMessage(m); })"
                          OnKeyDown="@HandleKeyDown">
                @{ var i = 0; }
                @foreach (var m in context.Items)
                {
                    var idx = i++;
                    <SpectreTR @key="m.SequenceNumber" RowIndex="@idx">
                        <SpectreTD Align="Justify.Right">@m.SequenceNumber</SpectreTD>
                        <SpectreTD>@Truncate(m.MessageId, 30)</SpectreTD>
                        <SpectreTD>@Truncate(m.Subject, 25)</SpectreTD>
                        <SpectreTD>@m.EnqueuedTime.LocalDateTime.ToString("HH:mm:ss")</SpectreTD>
                        <SpectreTD Align="Justify.Right">@m.DeliveryCount</SpectreTD>
                    </SpectreTR>
                }
            </SpectreTBody>
        </SpectreTable>
        </Scrollable>
    }
    else
    {
        <Padder Padding="@(new(0, 1, 0, 0))">
            <Markup Content="No messages. Use F7 Peek or F8 Receive to load." Foreground="@Color.Grey" Decoration="@Decoration.Italic" />
        </Padder>
    }

    <Padder Padding="@(new(1, 0, 0, 0))">
        <Columns>
            <TextButton Content="[F7] Peek" OnClick="PeekMessages" FocusedColor="@Color.Green" FocusOrder="1" OnKeyDown="@HandleKeyDown" />
            <Markup Content="   " />
            <TextButton Content="[F8] Receive" OnClick="ReceiveMessages" FocusedColor="@Color.Red" FocusOrder="2" OnKeyDown="@HandleKeyDown" />
            <Markup Content="   " />
            @if (!_isDlq)
            {
                <TextButton Content="[F6] View DLQ" OnClick="@(() => SwitchDlq(true))" FocusedColor="@Color.Yellow" FocusOrder="3" OnKeyDown="@HandleKeyDown" />
            }
            else
            {
                <TextButton Content="[F6] View Active" OnClick="@(() => SwitchDlq(false))" FocusedColor="@Color.Green" FocusOrder="3" OnKeyDown="@HandleKeyDown" />
            }
            <Markup Content="   " />
            @if (_isDlq)
            {
                <TextButton Content="[F10] Requeue" OnClick="RequeueMessage" FocusedColor="@Color.Green" FocusOrder="4" OnKeyDown="@HandleKeyDown" />
                <Markup Content="   " />
            }
            <TextButton Content="[F9] Delete" OnClick="TriggerDelete" FocusedColor="@Color.Red" FocusOrder="5" OnKeyDown="@HandleKeyDown" />
            <Markup Content="   " />
            <TextButton Content="[Esc] Back" OnClick="@(() => Nav.NavigateTo("/queues"))" FocusedColor="@Color.Yellow" FocusOrder="6" OnKeyDown="@HandleKeyDown" />
        </Columns>
    </Padder>
</Rows>

<ConfirmModal IsOpened="@(_pendingDelete is not null)"
              Message="@($"Delete message #{_pendingDelete?.SequenceNumber}?")"
              OnConfirm="ConfirmDelete"
              OnCancel="@(() => _pendingDelete = null)" />

<ErrorModal Message="@_error" OnDismiss="@(() => _error = string.Empty)" />

@code {
    [Parameter] public string QueueName { get; set; } = "";

    private bool _isDlq = true;
    private List<MessageInfo> _messages = [];
    private bool _loading;
    private string _error = string.Empty;
    private int _selectedIndex;
    private MessageInfo? _focusedMessage;
    private MessageInfo? _pendingDelete;

    private const int FetchLimit = 100;
    private MessageSource Source => new(QueueName, _isDlq);


    protected override void OnInitialized()
    {
        if (Connection.CurrentNamespace is null)
            Nav.NavigateTo("/");
    }

    protected override async Task OnInitializedAsync() => await PeekMessages();

    private async Task SwitchDlq(bool dlq) { _isDlq = dlq; _messages = []; _selectedIndex = 0; _focusedMessage = null; await PeekMessages(); }

    private async Task PeekMessages()
    {
        _loading = true; _error = string.Empty; StateHasChanged();
        try { _messages = await MessageService.PeekMessagesAsync(QueueName, FetchLimit, _isDlq); }
        catch (Exception ex) { _error = ex.Message; }
        _focusedMessage = _messages.ElementAtOrDefault(_selectedIndex);
        _loading = false; StateHasChanged();
    }

    private async Task ReceiveMessages()
    {
        _loading = true; _error = string.Empty; StateHasChanged();
        try { _messages = await MessageService.ReceiveMessagesAsync(QueueName, FetchLimit, _isDlq); }
        catch (Exception ex) { _error = ex.Message; }
        _focusedMessage = _messages.ElementAtOrDefault(_selectedIndex);
        _loading = false; StateHasChanged();
    }

    private void ViewMessage(MessageInfo msg)
    {
        NavState.Message = msg;
        NavState.MessageSource = Source;
        Nav.NavigateTo("/message");
    }

    private void TriggerDelete()
    {
        if (_focusedMessage is not null) { _pendingDelete = _focusedMessage; StateHasChanged(); }
    }

    private async Task ConfirmDelete()
    {
        var msg = _pendingDelete!;
        _pendingDelete = null; _error = string.Empty; StateHasChanged();
        try { await MessageService.DeleteMessageAsync(Source, msg.SequenceNumber); _messages.Remove(msg); _selectedIndex = Math.Min(_selectedIndex, Math.Max(0, _messages.Count - 1)); _focusedMessage = _messages.ElementAtOrDefault(_selectedIndex); }
        catch (Exception ex) { _error = ex.Message; }
        StateHasChanged();
    }

    private async Task RequeueMessage()
    {
        if (_focusedMessage is null) return;
        var msg = _focusedMessage;
        _error = string.Empty; StateHasChanged();
        try
        {
            await MessageService.RequeueMessageAsync(Source, msg.SequenceNumber);
            _messages.Remove(msg);
            _focusedMessage = _messages.ElementAtOrDefault(_selectedIndex);
        }
        catch (Exception ex) { _error = ex.Message; }
        StateHasChanged();
    }

    private void HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.CtrlKey || e.AltKey || e.MetaKey) return;
        switch (e.Key)
        {
            case "Escape":
                if (_pendingDelete is not null) { _pendingDelete = null; StateHasChanged(); return; }
                Nav.NavigateTo("/queues"); return;
            case "F6": _ = SwitchDlq(!_isDlq); return;
            case "F7": _ = PeekMessages(); return;
            case "F8": _ = ReceiveMessages(); return;
            case "F9": case "Delete": case "\\": TriggerDelete(); return;
            case "F10": if (_isDlq && _focusedMessage is not null) _ = RequeueMessage(); return;
        }
    }

    private static string Truncate(string value, int maxLength) =>
        value.Length <= maxLength ? value : value[..(maxLength - 1)] + "…";
}

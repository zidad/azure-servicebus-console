@namespace LLMAgentTUI.Components
@using Microsoft.AspNetCore.Components.Web
@using RazorConsole.Components
@using ServiceBusConsole

<Rows @onkeydown="HandleGlobalKeyDown">
    @switch (_screen)
    {
        case Screen.Connection:
            <ConnectionScreen OnBrowseQueues="@(() => Navigate(Screen.QueueList))"
                              OnBrowseTopics="@(() => Navigate(Screen.TopicList))"
                              OnBrowseAllSubscriptions="@(() => Navigate(Screen.AllSubscriptions))" />
            break;

        case Screen.QueueList:
            <QueueListScreen OnBack="@GoBack"
                             OnBrowseQueue="@(args => NavigateToQueue(args.Name, args.Dlq))" />
            break;

        case Screen.TopicList:
            <TopicListScreen OnBack="@GoBack"
                             OnBrowseTopic="@(name => NavigateToSubscriptionList(name))" />
            break;

        case Screen.SubscriptionList:
            <SubscriptionListScreen TopicName="@(_topicName!)"
                                    OnBack="@GoBack"
                                    OnBrowseSubscription="@(args => NavigateToSubscriptionBrowser(args.TopicName, args.SubscriptionName))" />
            break;

        case Screen.AllSubscriptions:
            <AllSubscriptionsScreen OnBack="@GoBack"
                                    OnBrowseSubscription="@(args => NavigateToSubscriptionBrowser(args.TopicName, args.SubscriptionName))" />
            break;

        case Screen.QueueBrowser:
            <QueueBrowserScreen QueueName="@(_queueName!)"
                                OnBack="@GoBack"
                                OnViewMessage="@(args => NavigateToMessage(args.Message, args.Source))" />
            break;

        case Screen.SubscriptionBrowser:
            <SubscriptionBrowserScreen TopicName="@(_topicName!)"
                                       SubscriptionName="@(_subscriptionName!)"
                                       OnBack="@GoBack"
                                       OnViewMessage="@(args => NavigateToMessage(args.Message, args.Source))" />
            break;

        case Screen.MessageDetail:
            <MessageDetailScreen Message="@(_viewingMessage!)"
                                 Source="@(_messageSource!)"
                                 OnBack="@GoBack" />
            break;
    }
</Rows>

@code {
    private enum Screen
    {
        Connection, QueueList, TopicList, SubscriptionList, AllSubscriptions,
        QueueBrowser, SubscriptionBrowser, MessageDetail
    }

    private Screen _screen = Screen.Connection;
    private Screen _previousScreen = Screen.Connection;
    private string? _queueName;
    private string? _topicName;
    private string? _subscriptionName;
    private MessageInfo? _viewingMessage;
    private MessageSource? _messageSource;

    private void GoBack()
    {
        _screen = _screen switch
        {
            Screen.MessageDetail     => _previousScreen,
            Screen.QueueBrowser      => Screen.QueueList,
            Screen.SubscriptionBrowser => _previousScreen,
            Screen.SubscriptionList  => Screen.TopicList,
            Screen.QueueList         => Screen.Connection,
            Screen.TopicList         => Screen.Connection,
            Screen.AllSubscriptions  => Screen.Connection,
            _                        => Screen.Connection
        };
        StateHasChanged();
    }

    private void HandleGlobalKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Escape" && _screen != Screen.Connection)
            GoBack();
    }

    private void Navigate(Screen screen)
    {
        _screen = screen;
        StateHasChanged();
    }

    private void NavigateToQueue(string name, bool dlq)
    {
        _queueName = name;
        _screen = Screen.QueueBrowser;
        StateHasChanged();
    }

    private void NavigateToSubscriptionList(string topicName)
    {
        _topicName = topicName;
        _screen = Screen.SubscriptionList;
        StateHasChanged();
    }

    private void NavigateToSubscriptionBrowser(string topicName, string subscriptionName)
    {
        _previousScreen = _screen;
        _topicName = topicName;
        _subscriptionName = subscriptionName;
        _screen = Screen.SubscriptionBrowser;
        StateHasChanged();
    }

    private void NavigateToMessage(MessageInfo msg, MessageSource source)
    {
        _previousScreen = _screen;
        _viewingMessage = msg;
        _messageSource = source;
        _screen = Screen.MessageDetail;
        StateHasChanged();
    }
}

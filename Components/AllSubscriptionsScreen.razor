@namespace LLMAgentTUI.Components
@implements IDisposable

@inject ITopicService TopicService

<Rows @onkeydown="HandleKeyDown">
    <Columns>
        <Markup Content="All Subscriptions" Foreground="@Color.DodgerBlue1" Decoration="@Decoration.Bold" />
        <Markup Content="  " />
        <TextButton Content="< Back" OnClick="@(() => OnBack.InvokeAsync())" FocusedColor="@Color.Yellow" FocusOrder="2" />
        <Markup Content="  " />
        <TextButton Content="Refresh" OnClick="LoadSubscriptions" FocusedColor="@Color.Green" FocusOrder="3" />
    </Columns>

    <Padder Padding="@(new(0, 1, 0, 0))">
        <TextInput Value="@_filter"
                   ValueChanged="ApplyFilter"
                   OnFocus="@(_ => _filterFocused = true)"
                   OnBlur="@(_ => _filterFocused = false)"
                   Placeholder="Type to filter by topic or subscription..."
                   Expand="true"
                   FocusOrder="1" />
    </Padder>

    @if (_all.Count == 0)
    {
        <Padder Padding="@(new(0, 1, 0, 0))">
            <Columns>
                <RazorConsole.Components.Spinner SpinnerType="@Spectre.Console.Spinner.Known.Dots" />
                <Markup Content="Loading subscriptions..." Foreground="@Color.Grey" Decoration="@Decoration.Italic" />
            </Columns>
        </Padder>
    }
    else
    {
        <Padder Padding="@(new(0, 1, 0, 0))">
            <Markup Content="@($"{_filtered.Count} subscription(s)")" Foreground="@Color.Grey" />
        </Padder>

        <SpectreTable Expand="true" Border="TableBorder.Rounded">
            <SpectreTHead>
                <SpectreTR>
                    <SpectreTH Align="Justify.Left">Topic</SpectreTH>
                    <SpectreTH Align="Justify.Left">Subscription</SpectreTH>
                    <SpectreTH Align="Justify.Right">Active</SpectreTH>
                    <SpectreTH Align="Justify.Right">DLQ</SpectreTH>
                    <SpectreTH Align="Justify.Right">Transfer</SpectreTH>
                </SpectreTR>
            </SpectreTHead>
            <SpectreTBody>
                @{ var i = 0; }
                @foreach (var s in _filtered.Take(MaxRows))
                {
                    var captured = s;
                    var focusOrder = 4 + i++;
                    <SpectreTR @key="@($"{captured.TopicName}/{captured.Name}")">
                        <SpectreTD>@s.TopicName</SpectreTD>
                        <SpectreTD>
                            <TextButton Content="@captured.Name"
                                        OnClick="@(() => OnBrowseSubscription.InvokeAsync((captured.TopicName, captured.Name)))"
                                        FocusedColor="@Color.DodgerBlue1"
                                        FocusOrder="@focusOrder"
                                        OnFocus="@(_ => _focusedItem = captured)"
                                        OnBlur="@(_ => _focusedItem = null)" />
                        </SpectreTD>
                        <SpectreTD Align="Justify.Right">@s.ActiveMessageCount</SpectreTD>
                        <SpectreTD Align="Justify.Right">@(s.DeadLetterMessageCount > 0 ? $"! {s.DeadLetterMessageCount}" : "0")</SpectreTD>
                        <SpectreTD Align="Justify.Right">@s.TransferMessageCount</SpectreTD>
                    </SpectreTR>
                }
            </SpectreTBody>
        </SpectreTable>
    }
</Rows>

<ConfirmModal IsOpened="@(_pendingDelete is not null)"
              Message="@($"Delete subscription '{_pendingDelete?.Name}' from topic '{_pendingDelete?.TopicName}'? This cannot be undone.")"
              OnConfirm="ConfirmDelete"
              OnCancel="@(() => _pendingDelete = null)" />

@if (!string.IsNullOrEmpty(_error))
{
    <Padder Padding="@(new(0, 1, 0, 0))">
        <Panel BorderColor="@Color.Red" Title="Error" Expand="true">
            <Markup Content="@_error.Replace("[", "[[").Replace("]", "]]")" Foreground="@Color.Red" />
        </Panel>
    </Padder>
}

@code {
    [Parameter] public EventCallback OnBack { get; set; }
    [Parameter] public EventCallback<(string TopicName, string SubscriptionName)> OnBrowseSubscription { get; set; }

    private List<SubscriptionInfo> _all = [];
    private List<SubscriptionInfo> _filtered = [];
    private string? _filter;
    private bool _filterFocused;
    private SubscriptionInfo? _focusedItem;
    private SubscriptionInfo? _pendingDelete;
    private string _error = string.Empty;
    private CancellationTokenSource _cts = new();

    private static int MaxRows => Math.Max(5, Console.WindowHeight - 12);

    public void Dispose() { _cts.Cancel(); _cts.Dispose(); }

    protected override async Task OnInitializedAsync() => await LoadSubscriptions();

    private async Task LoadSubscriptions()
    {
        _cts.Cancel();
        _cts = new CancellationTokenSource();
        _error = string.Empty;

        var seen = new HashSet<string>(StringComparer.OrdinalIgnoreCase);

        try
        {
            await foreach (var s in TopicService.GetAllSubscriptionsAsync(_cts.Token))
            {
                var key = $"{s.TopicName}/{s.Name}";
                seen.Add(key);
                var idx = _all.FindIndex(x => x.TopicName == s.TopicName && x.Name == s.Name);
                if (idx >= 0) _all[idx] = s;
                else _all.Add(s);
                SortAndFilter();
            }

            if (!_cts.IsCancellationRequested)
            {
                _all.RemoveAll(s => !seen.Contains($"{s.TopicName}/{s.Name}"));
                SortAndFilter();
            }
        }
        catch (OperationCanceledException) { }
        catch (Exception ex) { _error = ex.Message; StateHasChanged(); }
    }

    private void SortAndFilter()
    {
        _all = [.. _all.OrderByDescending(s => s.TotalMessageCount).ThenBy(s => s.TopicName).ThenBy(s => s.Name)];
        ApplyFilter(_filter);
    }

    private void ApplyFilter(string? value)
    {
        _filter = value;
        _filtered = string.IsNullOrWhiteSpace(value)
            ? _all
            : _all.Where(s =>
                s.TopicName.Contains(value, StringComparison.OrdinalIgnoreCase) ||
                s.Name.Contains(value, StringComparison.OrdinalIgnoreCase))
              .ToList();
        StateHasChanged();
    }

    private void HandleKeyDown(KeyboardEventArgs e)
    {
        if (_filterFocused || e.CtrlKey || e.AltKey || e.MetaKey) return;
        if (e.Key == "Backspace")
        {
            if (_focusedItem is not null) { _pendingDelete = _focusedItem; StateHasChanged(); }
            else ApplyFilter(string.IsNullOrEmpty(_filter) ? null : _filter[..^1]);
            return;
        }
        if (e.Key.Length == 1 && !char.IsControl(e.Key[0])) ApplyFilter((_filter ?? "") + e.Key);
    }

    private async Task ConfirmDelete()
    {
        var sub = _pendingDelete!;
        _pendingDelete = null;
        _error = string.Empty;
        StateHasChanged();

        try
        {
            await TopicService.DeleteSubscriptionAsync(sub.TopicName, sub.Name);
            _all.RemoveAll(s => s.TopicName == sub.TopicName && s.Name == sub.Name);
            SortAndFilter();
        }
        catch (Exception ex) { _error = ex.Message; StateHasChanged(); }
    }
}

@namespace LLMAgentTUI.Components
@implements IDisposable

@inject IMessageService MessageService

<Rows>
    <Columns>
        <Markup Content="@($"{QueueName}{(_isDlq ? " (DLQ)" : "")}")"
                Foreground="@Color.DodgerBlue1" Decoration="@Decoration.Bold" />
        <Markup Content="  " />
        <TextButton Content="< Back" OnClick="@(() => OnBack.InvokeAsync())" FocusedColor="@Color.Yellow" FocusOrder="1" />
    </Columns>

    <Padder Padding="@(new(0, 1, 0, 0))">
        <Columns>
            <TextButton Content="Peek from start" OnClick="PeekMessages" FocusedColor="@Color.Green" FocusOrder="2" />
            <Markup Content="  " />
            <TextButton Content="Receive (destructive)" OnClick="ReceiveMessages" FocusedColor="@Color.Red" FocusOrder="3" />
            <Markup Content="  " />
            @if (!_isDlq)
            {
                <TextButton Content="View DLQ"
                            OnClick="@(() => SwitchDlq(true))"
                            FocusedColor="@Color.Yellow"
                            FocusOrder="4" />
            }
            else
            {
                <TextButton Content="View active"
                            OnClick="@(() => SwitchDlq(false))"
                            FocusedColor="@Color.Green"
                            FocusOrder="4" />
            }
        </Columns>
    </Padder>

    @if (_loading)
    {
        <Padder Padding="@(new(0, 1, 0, 0))">
            <Columns>
                <RazorConsole.Components.Spinner SpinnerType="@Spectre.Console.Spinner.Known.Dots" />
                <Markup Content="Loading messages..." Foreground="@Color.Grey" Decoration="@Decoration.Italic" />
            </Columns>
        </Padder>
    }
    else if (_messages.Count > 0)
    {
        <Padder Padding="@(new(0, 1, 0, 0))">
            <Markup Content="@($"{_messages.Count} message(s)  |  Tab to navigate, Enter to view, Backspace to delete")" Foreground="@Color.Grey" />
        </Padder>

        <SpectreTable Expand="true" Border="TableBorder.Simple">
            <SpectreTHead>
                <SpectreTR>
                    <SpectreTH Align="Justify.Right">#</SpectreTH>
                    <SpectreTH Align="Justify.Left">Message ID</SpectreTH>
                    <SpectreTH Align="Justify.Left">Subject</SpectreTH>
                    <SpectreTH Align="Justify.Left">Enqueued</SpectreTH>
                    <SpectreTH Align="Justify.Right">Delivery</SpectreTH>
                </SpectreTR>
            </SpectreTHead>
            <SpectreTBody>
                @{ var i = 0; }
                @foreach (var m in _messages)
                {
                    var captured = m;
                    var focusOrder = 5 + i++;
                    <SpectreTR @key="captured.SequenceNumber">
                        <SpectreTD Align="Justify.Right">
                            <TextButton Content="@captured.SequenceNumber.ToString()"
                                        OnClick="@(() => OnViewMessage.InvokeAsync((captured, MessageSource)))"
                                        FocusedColor="@Color.DodgerBlue1"
                                        FocusOrder="@focusOrder"
                                        OnFocus="@(_ => _focusedMessage = captured)"
                                        OnBlur="@(_ => _focusedMessage = null)" />
                        </SpectreTD>
                        <SpectreTD>@Truncate(m.MessageId, 30)</SpectreTD>
                        <SpectreTD>@Truncate(m.Subject, 25)</SpectreTD>
                        <SpectreTD>@m.EnqueuedTime.LocalDateTime.ToString("HH:mm:ss")</SpectreTD>
                        <SpectreTD Align="Justify.Right">@m.DeliveryCount</SpectreTD>
                    </SpectreTR>
                }
            </SpectreTBody>
        </SpectreTable>
    }
    else
    {
        <Padder Padding="@(new(0, 1, 0, 0))">
            <Markup Content="No messages. Use Peek or Receive to load." Foreground="@Color.Grey" Decoration="@Decoration.Italic" />
        </Padder>
    }
</Rows>

<ConfirmModal IsOpened="@(_pendingDelete is not null)"
              Message="@($"Delete message #{_pendingDelete?.SequenceNumber}?")"
              OnConfirm="ConfirmDelete"
              OnCancel="@(() => _pendingDelete = null)" />

@if (!string.IsNullOrEmpty(_error))
{
    <Padder Padding="@(new(0, 1, 0, 0))">
        <Panel BorderColor="@Color.Red" Title="Error" Expand="true">
            <Markup Content="@_error.Replace("[", "[[").Replace("]", "]]")" Foreground="@Color.Red" />
        </Panel>
    </Padder>
}

@code {
    [Parameter, EditorRequired] public string QueueName { get; set; } = "";
    [Parameter] public EventCallback OnBack { get; set; }
    [Parameter] public EventCallback<(MessageInfo Message, MessageSource Source)> OnViewMessage { get; set; }

    private bool _isDlq;
    private List<MessageInfo> _messages = [];
    private bool _loading;
    private string _error = string.Empty;
    private MessageInfo? _focusedMessage;
    private MessageInfo? _pendingDelete;

    private static int MaxRows => Math.Max(5, Console.WindowHeight - 12);
    private MessageSource MessageSource => new(QueueName, _isDlq);

    public void Dispose() { }

    protected override async Task OnInitializedAsync() => await PeekMessages();

    private async Task SwitchDlq(bool dlq)
    {
        _isDlq = dlq;
        _messages = [];
        await PeekMessages();
    }

    private async Task PeekMessages()
    {
        _loading = true;
        _error = string.Empty;
        StateHasChanged();

        try { _messages = await MessageService.PeekMessagesAsync(QueueName, MaxRows, _isDlq); }
        catch (Exception ex) { _error = ex.Message; }

        _loading = false;
        StateHasChanged();
    }

    private async Task ReceiveMessages()
    {
        _loading = true;
        _error = string.Empty;
        StateHasChanged();

        try { _messages = await MessageService.ReceiveMessagesAsync(QueueName, MaxRows, _isDlq); }
        catch (Exception ex) { _error = ex.Message; }

        _loading = false;
        StateHasChanged();
    }

    public void HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Backspace" && _focusedMessage is not null)
            _pendingDelete = _focusedMessage;
    }

    private async Task ConfirmDelete()
    {
        var msg = _pendingDelete!;
        _pendingDelete = null;
        _error = string.Empty;
        StateHasChanged();

        try
        {
            await MessageService.DeleteMessageAsync(MessageSource, msg.SequenceNumber);
            _messages.Remove(msg);
        }
        catch (Exception ex) { _error = ex.Message; }

        StateHasChanged();
    }

    private static string Truncate(string value, int maxLength) =>
        value.Length <= maxLength ? value : value[..(maxLength - 1)] + "…";
}

@namespace LLMAgentTUI.Components
@implements IDisposable

@inject ITopicService TopicService

<Rows>
    <Columns>
        <Markup Content="@($"Subscriptions — {TopicName}")" Foreground="@Color.DodgerBlue1" Decoration="@Decoration.Bold" />
        <Markup Content="  " />
        <TextButton Content="< Back" OnClick="@(() => OnBack.InvokeAsync())" FocusedColor="@Color.Yellow" FocusOrder="1" />
        <Markup Content="  " />
        <TextButton Content="Refresh" OnClick="LoadSubscriptions" FocusedColor="@Color.Green" FocusOrder="2" />
    </Columns>

    @if (_subscriptions.Count == 0)
    {
        <Padder Padding="@(new(0, 1, 0, 0))">
            <Columns>
                <RazorConsole.Components.Spinner SpinnerType="@Spectre.Console.Spinner.Known.Dots" />
                <Markup Content="Loading subscriptions..." Foreground="@Color.Grey" Decoration="@Decoration.Italic" />
            </Columns>
        </Padder>
    }
    else
    {
        <Padder Padding="@(new(0, 1, 0, 0))">
            <Markup Content="@($"{_subscriptions.Count} subscription(s)  |  Enter to browse, Backspace to delete")" Foreground="@Color.Grey" />
        </Padder>

        <SpectreTable Expand="true" Border="TableBorder.Rounded">
            <SpectreTHead>
                <SpectreTR>
                    <SpectreTH Align="Justify.Left">Subscription</SpectreTH>
                    <SpectreTH Align="Justify.Right">Active</SpectreTH>
                    <SpectreTH Align="Justify.Right">DLQ</SpectreTH>
                    <SpectreTH Align="Justify.Right">Transfer</SpectreTH>
                </SpectreTR>
            </SpectreTHead>
            <SpectreTBody>
                @{ var i = 0; }
                @foreach (var s in _subscriptions)
                {
                    var captured = s;
                    var focusOrder = 3 + i++;
                    <SpectreTR @key="captured.Name">
                        <SpectreTD>
                            <TextButton Content="@captured.Name"
                                        OnClick="@(() => OnBrowseSubscription.InvokeAsync((TopicName, captured.Name)))"
                                        FocusedColor="@Color.DodgerBlue1"
                                        FocusOrder="@focusOrder"
                                        OnFocus="@(_ => _focusedItem = captured.Name)"
                                        OnBlur="@(_ => _focusedItem = null)" />
                        </SpectreTD>
                        <SpectreTD Align="Justify.Right">@s.ActiveMessageCount</SpectreTD>
                        <SpectreTD Align="Justify.Right">@(s.DeadLetterMessageCount > 0 ? $"! {s.DeadLetterMessageCount}" : "0")</SpectreTD>
                        <SpectreTD Align="Justify.Right">@s.TransferMessageCount</SpectreTD>
                    </SpectreTR>
                }
            </SpectreTBody>
        </SpectreTable>
    }
</Rows>

<ConfirmModal IsOpened="@(_pendingDelete is not null)"
              Message="@($"Delete subscription '{_pendingDelete}' from topic '{TopicName}'? This cannot be undone.")"
              OnConfirm="ConfirmDelete"
              OnCancel="@(() => _pendingDelete = null)" />

<ErrorModal Message="@_error" OnDismiss="@(() => _error = string.Empty)" />

@code {
    [Parameter, EditorRequired] public string TopicName { get; set; } = "";
    [Parameter] public EventCallback OnBack { get; set; }
    [Parameter] public EventCallback<(string TopicName, string SubscriptionName)> OnBrowseSubscription { get; set; }

    private List<SubscriptionInfo> _subscriptions = [];
    private string? _focusedItem;
    private string? _pendingDelete;
    private string _error = string.Empty;
    private CancellationTokenSource _cts = new();

    public void Dispose() { _cts.Cancel(); _cts.Dispose(); }

    protected override async Task OnInitializedAsync() => await LoadSubscriptions();

    private async Task LoadSubscriptions()
    {
        _cts.Cancel();
        _cts = new CancellationTokenSource();
        _error = string.Empty;

        var seen = new HashSet<string>(StringComparer.OrdinalIgnoreCase);

        try
        {
            await foreach (var s in TopicService.GetSubscriptionsAsync(TopicName, _cts.Token))
            {
                seen.Add(s.Name);
                var idx = _subscriptions.FindIndex(x => x.Name == s.Name);
                if (idx >= 0) _subscriptions[idx] = s;
                else _subscriptions.Add(s);
                await InvokeAsync(StateHasChanged);
            }

            if (!_cts.IsCancellationRequested)
            {
                _subscriptions.RemoveAll(s => !seen.Contains(s.Name));
                StateHasChanged();
            }
        }
        catch (OperationCanceledException) { }
        catch (Exception ex) { _error = ex.Message; StateHasChanged(); }
    }

    public void HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Backspace" && _focusedItem is not null)
        {
            _pendingDelete = _focusedItem;
            StateHasChanged();
        }
    }

    private async Task ConfirmDelete()
    {
        var name = _pendingDelete!;
        _pendingDelete = null;
        _error = string.Empty;
        StateHasChanged();

        try
        {
            await TopicService.DeleteSubscriptionAsync(TopicName, name);
            _subscriptions.RemoveAll(s => s.Name == name);
            StateHasChanged();
        }
        catch (Exception ex) { _error = ex.Message; StateHasChanged(); }
    }
}

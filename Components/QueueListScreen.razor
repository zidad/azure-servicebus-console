@namespace LLMAgentTUI.Components
@implements IDisposable

@inject IQueueService QueueService
@inject IMessageService MessageService

<Rows @onkeydown="HandleKeyDown">
    <Columns>
        <Markup Content="Queues" Foreground="@Color.DodgerBlue1" Decoration="@Decoration.Bold" />
        <Markup Content="  " />
        <TextButton Content="< Back" OnClick="@(() => OnBack.InvokeAsync())" FocusedColor="@Color.Yellow" FocusOrder="2" />
        <Markup Content="  " />
        <TextButton Content="Refresh" OnClick="LoadQueues" FocusedColor="@Color.Green" FocusOrder="3" />
    </Columns>

    <Padder Padding="@(new(0, 1, 0, 0))">
        <TextInput Value="@_filter"
                   ValueChanged="ApplyFilter"
                   OnFocus="@(_ => _filterFocused = true)"
                   OnBlur="@(_ => _filterFocused = false)"
                   Placeholder="Type to filter..."
                   Expand="true"
                   FocusOrder="1" />
    </Padder>

    @if (_all.Count == 0)
    {
        <Padder Padding="@(new(0, 1, 0, 0))">
            <Columns>
                <RazorConsole.Components.Spinner SpinnerType="@Spectre.Console.Spinner.Known.Dots" />
                <Markup Content="Loading queues..." Foreground="@Color.Grey" Decoration="@Decoration.Italic" />
            </Columns>
        </Padder>
    }
    else
    {
        <Padder Padding="@(new(0, 1, 0, 0))">
            <Markup Content="@($"{_filtered.Count} queue(s)")" Foreground="@Color.Grey" />
        </Padder>

        <SpectreTable Expand="true" Border="TableBorder.Rounded">
            <SpectreTHead>
                <SpectreTR>
                    <SpectreTH Align="Justify.Left">Queue</SpectreTH>
                    <SpectreTH Align="Justify.Right">Active</SpectreTH>
                    <SpectreTH Align="Justify.Right">DLQ</SpectreTH>
                    <SpectreTH Align="Justify.Right">Scheduled</SpectreTH>
                    <SpectreTH Align="Justify.Right">Transfer</SpectreTH>
                </SpectreTR>
            </SpectreTHead>
            <SpectreTBody>
                @{ var i = 0; }
                @foreach (var q in _filtered.Take(MaxRows))
                {
                    var captured = q;
                    var focusOrder = 4 + i++;
                    <SpectreTR @key="captured.Name">
                        <SpectreTD>
                            <TextButton Content="@captured.Name"
                                        OnClick="@(() => OnBrowseQueue.InvokeAsync((captured.Name, false)))"
                                        FocusedColor="@Color.DodgerBlue1"
                                        FocusOrder="@focusOrder"
                                        OnFocus="@(_ => _focusedItem = captured.Name)"
                                        OnBlur="@(_ => _focusedItem = null)"
                                        OnKeyDown="@HandleKeyDown" />
                        </SpectreTD>
                        <SpectreTD Align="Justify.Right">@(q.IsRefreshing ? "…" : q.ActiveMessageCount.ToString())</SpectreTD>
                        <SpectreTD Align="Justify.Right">@(q.IsRefreshing ? "…" : q.DeadLetterMessageCount > 0 ? $"! {q.DeadLetterMessageCount}" : "0")</SpectreTD>
                        <SpectreTD Align="Justify.Right">@(q.IsRefreshing ? "…" : q.ScheduledMessageCount.ToString())</SpectreTD>
                        <SpectreTD Align="Justify.Right">@(q.IsRefreshing ? "…" : q.TransferMessageCount.ToString())</SpectreTD>
                    </SpectreTR>
                }
            </SpectreTBody>
        </SpectreTable>
    }
</Rows>

<ConfirmModal IsOpened="@(_pendingDelete is not null)"
              Message="@($"Delete queue '{_pendingDelete}'? This cannot be undone.")"
              OnConfirm="ConfirmDelete"
              OnCancel="@(() => _pendingDelete = null)" />

<ErrorModal Message="@_error" OnDismiss="@(() => _error = string.Empty)" />

@code {
    [Parameter] public EventCallback OnBack { get; set; }
    [Parameter] public EventCallback<(string Name, bool Dlq)> OnBrowseQueue { get; set; }

    private List<QueueInfo> _all = [];
    private List<QueueInfo> _filtered = [];
    private string? _filter;
    private bool _filterFocused;
    private string? _focusedItem;
    private string? _pendingDelete;
    private string _error = string.Empty;
    private CancellationTokenSource _cts = new();

    private static int MaxRows => Math.Max(5, Console.WindowHeight - 12);

    public void Dispose() { _cts.Cancel(); _cts.Dispose(); }

    protected override async Task OnInitializedAsync() => await LoadQueues();

    private async Task LoadQueues()
    {
        _cts.Cancel();
        _cts = new CancellationTokenSource();
        _error = string.Empty;

        var seen = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
        var transitionRendered = false;

        try
        {
            await foreach (var q in QueueService.GetQueuesAsync(_cts.Token))
            {
                seen.Add(q.Name);
                var idx = _all.FindIndex(x => x.Name == q.Name);
                if (idx >= 0) _all[idx] = q;
                else _all.Add(q);

                if (!q.IsRefreshing && !transitionRendered)
                {
                    transitionRendered = true;
                    SortAndUpdateFilterState();
                    await InvokeAsync(StateHasChanged);
                }
            }

            if (!_cts.IsCancellationRequested)
            {
                _all.RemoveAll(q => !seen.Contains(q.Name));
                SortAndUpdateFilterState();
            }

            await InvokeAsync(StateHasChanged);
        }
        catch (OperationCanceledException) { }
        catch (Exception ex) { _error = ex.Message; await InvokeAsync(StateHasChanged); }
    }

    private void SortAndUpdateFilterState()
    {
        _all = [.. _all.OrderByDescending(q => q.DeadLetterMessageCount).ThenBy(q => q.Name)];
        UpdateFilterState(_filter);
    }

    private void UpdateFilterState(string? value)
    {
        _filter = value;
        _filtered = string.IsNullOrWhiteSpace(value)
            ? _all
            : _all.Where(q => q.Name.Contains(value, StringComparison.OrdinalIgnoreCase)).ToList();
    }

    private void SortAndFilter()
    {
        _all = [.. _all.OrderByDescending(q => q.DeadLetterMessageCount).ThenBy(q => q.Name)];
        ApplyFilter(_filter);
    }

    private void ApplyFilter(string? value)
    {
        _filter = value;
        _filtered = string.IsNullOrWhiteSpace(value)
            ? _all
            : _all.Where(q => q.Name.Contains(value, StringComparison.OrdinalIgnoreCase)).ToList();
        StateHasChanged();
    }

    private void HandleKeyDown(KeyboardEventArgs e)
    {
        if (_filterFocused || e.CtrlKey || e.AltKey || e.MetaKey) return;
        if (e.Key == "Backspace")
        {
            if (_focusedItem is not null) { _pendingDelete = _focusedItem; StateHasChanged(); }
            else ApplyFilter(string.IsNullOrEmpty(_filter) ? null : _filter[..^1]);
            return;
        }
        if (e.Key.Length == 1 && !char.IsControl(e.Key[0])) ApplyFilter((_filter ?? "") + e.Key);
    }

    private async Task ConfirmDelete()
    {
        var name = _pendingDelete!;
        _pendingDelete = null;
        _error = string.Empty;
        StateHasChanged();

        try
        {
            await QueueService.DeleteQueueAsync(name);
            _all.RemoveAll(q => q.Name == name);
            SortAndFilter();
        }
        catch (Exception ex) { _error = ex.Message; StateHasChanged(); }
    }
}
